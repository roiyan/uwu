# Copy to .env.local and fill in. Never commit the real .env.local.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Pooler URL (port 6543) — wajib untuk Drizzle + concurrent connections.
# Get it from: Supabase Dashboard → Project Settings → Database → Connection pooling → Transaction mode.
DATABASE_URL=postgres://postgres.YOUR-PROJECT:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# --- Midtrans (Sprint 3) ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# --- WhatsApp Cloud API (Sprint 3) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- Claude API (AI copywriter, Sprint 1+) ---
ANTHROPIC_API_KEY=

# --- Gemini (Broadcast AI assistant) ---
# Backs `generateBroadcastMessage` in src/lib/actions/ai-message.ts.
# Get a key at https://aistudio.google.com/app/apikey. The action
# soft-fails with "Asisten AI belum diaktifkan" when this is unset,
# so leaving it blank only disables the AI broadcast helper — it
# doesn't break the rest of the app.
GEMINI_API_KEY=

# --- SendGrid (email undangan, Sprint 3) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@uwu.id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Wildcard invitation subdomain. Leave empty for staging/local — the
# invitation URL falls back to NEXT_PUBLIC_APP_URL/<slug>. In
# production, set to the apex (e.g. `uwu.id`) AFTER the Vercel
# wildcard domain `*.uwu.id` is verified. The middleware then
# rewrites `<slug>.<root>` → `/<slug>` so the App Router can render
# the invitation page; buildInvitationUrl() emits the subdomain
# shape for broadcasts and QR codes.
NEXT_PUBLIC_ROOT_DOMAIN=

# --- Vercel Cron ---
# Vercel injects this as `Authorization: Bearer ${CRON_SECRET}` on the
# scheduled GET /api/cron/send-scheduled request. Generate any random
# string (e.g., `openssl rand -hex 32`) and add it both here and in the
# Vercel project env vars. Leave unset locally to allow unauth'd hits.
CRON_SECRET=
